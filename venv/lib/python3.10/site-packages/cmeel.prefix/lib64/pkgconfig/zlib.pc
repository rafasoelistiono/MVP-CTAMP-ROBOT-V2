prefix=${pcfiledir}/../..
exec_prefix=${pcfiledir}/../..
libdir=${exec_prefix}/lib64
sharedlibdir=${exec_prefix}/lib64
includedir=${exec_prefix}/include

Name: zlib
Description: zlib compression library
Version: 1.3.2
License: Zlib

Requires:
Libs: -L${libdir} -L${sharedlibdir} -lz
Cflags: -I${includedir}
