OPENAI_API_KEY=your_openai_api_key_here

# Simulation
MODEL_FILE=models/panda.xml
ENABLE_VIEWER=true

# OMPL motion planning
OMPL_ENABLED=true
OMPL_PLANNER_NAME=RRTConnect
OMPL_FRAGILE_PLANNER_NAME=BITstar
OMPL_TIME_LIMIT=3.0
OMPL_STATE_VALIDITY_RESOLUTION=0.005
OMPL_SAMPLER_RANGE=0.08
OMPL_WAYPOINT_STEP=0.015
OMPL_GOAL_TOLERANCE=0.001

# Execution safety
USE_IK_FALLBACK=false
SETTLE_STEPS_PER_WAYPOINT=8
FINAL_SETTLE_STEPS=15
